{

  "version": 3,

  "configurePresets": [

    {

      "name": "base",

      "hidden": true,

      "generator": "Ninja",

      "binaryDir": "${sourceDir}/build/${presetName}",

      "environment": {

        "CUDA_HOME": "/home/daking/.conda/envs/daking",

        "CUDA_PATH": "/home/daking/.conda/envs/daking",

        "LD_LIBRARY_PATH": "/home/daking/.conda/envs/daking/lib:/home/daking/.conda/envs/daking/targets/x86_64-linux/lib:$penv{LD_LIBRARY_PATH}",

        "PATH": "/home/daking/.conda/envs/daking/bin:/home/daking/.conda/envs/daking/targets/x86_64-linux/bin:$penv{PATH}"

      },

      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "/home/daking/.conda/envs/daking;/home/daking/.conda/envs/daking/targets/x86_64-linux",

        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",

        "CMAKE_CUDA_ARCHITECTURES": "89",

        "CMAKE_CUDA_COMPILER": "/home/daking/.conda/envs/daking/bin/nvcc",

        "Torch_DIR": "/home/daking/.conda/envs/daking/lib/python3.10/site-packages/torch/share/cmake/Torch",

        "CUDA_TOOLKIT_ROOT_DIR": "/home/daking/.conda/envs/daking/targets/x86_64-linux",

        "CUDA_INCLUDE_DIRS": "/home/daking/.conda/envs/daking/targets/x86_64-linux/include",

        "Python_EXECUTABLE": "/home/daking/.conda/envs/daking/bin/python",

        "Python_FIND_STRATEGY": "LOCATION"

      }

    },

    {

      "name": "linux-gcc-base",

      "displayName": "GCC Base",

      "inherits": "base",

      "hidden": true,

      "cacheVariables": {

        "CMAKE_C_COMPILER": "gcc",

        "CMAKE_CXX_COMPILER": "g++",

        "CMAKE_CUDA_HOST_COMPILER": "g++"

      }

    },

    {

      "name": "infra-dev-debug",

      "displayName": "Infra: GCC Debug",

      "description": "基础调试",

      "inherits": "linux-gcc-base",

      "cacheVariables": {

        "CMAKE_BUILD_TYPE": "Debug",

        "CMAKE_CXX_FLAGS": "-fno-omit-frame-pointer"

      }

    },

    {

      "name": "infra-dev-asan",

      "displayName": "Infra: GCC AddressSan (ASan)",

      "description": "内存调试",

      "inherits": "linux-gcc-base",

      "cacheVariables": {

        "CMAKE_BUILD_TYPE": "Debug",

        "CMAKE_CXX_FLAGS": "-fsanitize=address -fno-omit-frame-pointer"

      }

    },

    {

      "name": "infra-perf-profile",

      "displayName": "Infra: GCC Perf (RelWithStack)",

      "description": "性能调优：-O3 优化但保留调试符号",

      "inherits": "linux-gcc-base",

      "cacheVariables": {

        "CMAKE_BUILD_TYPE": "Release",

        "CMAKE_CXX_FLAGS": "-O3 -g -fno-omit-frame-pointer"

      }

    },

    {

      "name": "infra-prod-gcc",

      "displayName": "Infra: GCC Release (Production)",

      "description": "GCC Release",

      "inherits": "linux-gcc-base",

      "cacheVariables": {

        "CMAKE_BUILD_TYPE": "Release",

        "CMAKE_CXX_FLAGS": "-O3 -march=native -flto"

      }

    }

  ],

  "buildPresets": [

    { "name": "debug", "configurePreset": "infra-dev-debug" },

    { "name": "asan", "configurePreset": "infra-dev-asan" },

    { "name": "perf", "configurePreset": "infra-perf-profile" },

    { "name": "gcc-release", "configurePreset": "infra-prod-gcc" }

  ]

} 